  "keyFeatures": [
    "JWT-based token authentication with automatic expiry handling",
    "Persistent storage via cookies or localStorage",
    "Automatic token refresh with configurable intervals",
    "Private route protection for React Router and Next.js App Router",
    "Full TypeScript support with generic user state types",
    "RxJS-powered reactive state management",
    "Lightweight with minimal dependencies"
